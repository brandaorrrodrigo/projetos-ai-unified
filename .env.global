# =========================================
# VARIÁVEIS GLOBAIS - INFRAESTRUTURA UNIFICADA
# Criado em: 07/02/2026
# =========================================
# Este arquivo define variáveis compartilhadas
# entre todos os 9 projetos AI

# ========================================
# PostgreSQL Centralizado
# ========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_password_change_me_in_production
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_INITDB_ARGS=-E UTF8 --locale=en_US.UTF-8

# ========================================
# Redis Compartilhado
# ========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secure_password_change_me_in_production

# ========================================
# Ollama - IA Local Centralizada
# ========================================
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434

# Default model (pode ser mudado por projeto)
OLLAMA_MODEL=llama2

# ========================================
# Qdrant - Vector Database
# ========================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_PORT=6334

# ========================================
# Configurações Gerais
# ========================================
TZ=America/Sao_Paulo
NODE_ENV=development

# ========================================
# URLs Internas (Docker Network)
# ========================================
# Usado por serviços dentro do Docker
POSTGRES_INTERNAL_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432
REDIS_INTERNAL_URL=redis://:${REDIS_PASSWORD}@redis:6379
OLLAMA_INTERNAL_URL=http://ollama:11434
QDRANT_INTERNAL_URL=http://qdrant:6333

# ========================================
# URLs Externas (Para acessar do host)
# ========================================
# Usado para debug e ferramentas externas
POSTGRES_EXTERNAL_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432
REDIS_EXTERNAL_URL=redis://:${REDIS_PASSWORD}@localhost:6379
OLLAMA_EXTERNAL_URL=http://localhost:11434
QDRANT_EXTERNAL_URL=http://localhost:6333

# ========================================
# Logging
# ========================================
LOG_LEVEL=debug
LOG_FORMAT=json

# ========================================
# Backups
# ========================================
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *  # Diariamente às 2am
